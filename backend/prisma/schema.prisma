generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// DOMAINS
// ============================================

model Domain {
  id              String    @id @default(cuid())
  domain          String    @unique  // e.g. "www.maturapolski.pl"
  siteUrl         String    // e.g. "https://www.maturapolski.pl"
  
  // GSC property format
  gscProperty     String?   // e.g. "sc-domain:maturapolski.pl" or "https://www.maturapolski.pl/"
  
  // Sitemap config
  sitemapPath     String    @default("/sitemap-index.xml")
  
  // Metadata
  label           String?   // friendly name e.g. "Matura Polski"
  category        DomainCategory @default(OTHER)
  isActive        Boolean   @default(true)

  linkGroup       String?   // e.g. "EDU", "COPY", "MOTORS", "PERSONAL"
  linkRole        String?   // "MAIN" | "SATELLITE" | "SUPPORT"lastSitemapSync
  
  // Cached stats (updated by jobs)
  totalPages      Int       @default(0)
  indexedPages     Int       @default(0)
  avgPosition     Float?
  totalClicks     Int       @default(0)
  totalImpressions Int      @default(0)
  githubRepo      String?   // e.g. "LeszczynskiKarol/silnik-elektryczny-pl"
  lastGscPull     DateTime?
  lastCrawl       DateTime?
  lastSitemapSync DateTime?
  mozDA           Float?
  mozPA           Float?
  mozSpamScore    Float?
  mozLinks        Int?
  mozDomains      Int?
  mozAnchors      Json?
  mozLastSync     DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  pages           Page[]
  alerts          Alert[]
  gscDailyStats   GscDomainDaily[]
  seoEvents       SeoEvent[]
  backlinks       BacklinkSnapshot[]
  domainKeywords  DomainKeyword[]
  integrations DomainIntegration[]
  manualCosts ManualCost[]


  @@index([isActive])
}

enum DomainCategory {
  SAAS         // smart-copy.ai, smart-edu.ai, maturapolski.pl
  ECOMMERCE    // silniki-elektryczne.com.pl
  CONTENT_SITE // copywritingseo.pl, ebookcopywriting.pl
  SATELLITE    // SEO satellite domains
  OTHER
}

// ============================================
// PAGES
// ============================================

model Page {
  id              String    @id @default(cuid())
  domainId        String
  domain          Domain    @relation(fields: [domainId], references: [id], onDelete: Cascade)
  
  url             String    // full URL
  path            String    // just the path, e.g. "/baza-wiedzy/lalka"
  
  // Sitemap data
  inSitemap       Boolean   @default(true)
  sitemapLastmod   String?
  
  // Indexing status (from Google URL Inspection API)
  indexingVerdict  IndexingVerdict @default(UNKNOWN)
  coverageState   String?
  lastCrawlTime   DateTime?
  robotsTxtState  String?
  indexingState    String?
  pageFetchState  String?
  crawledAs       String?
  
  // Indexing tracking
  firstSubmitted  DateTime?
  lastSubmitted   DateTime?
  lastChecked     DateTime?
  statusChangedAt DateTime?
  previousVerdict IndexingVerdict?
  isTracked       Boolean   @default(false)
  
  // Cached GSC metrics (latest day)
  clicks          Int       @default(0)
  impressions     Int       @default(0)
  ctr             Float?
  position        Float?
  
  // Link stats (cached)
  internalLinksIn  Int      @default(0)  // other pages linking TO this page
  internalLinksOut Int      @default(0)  // this page linking TO other pages
  externalLinksOut Int      @default(0)  // outbound to external sites
  brokenLinksOut   Int      @default(0)
  
  // Page metadata
  title           String?
  metaDescription String?
  statusCode      Int?
  
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  gscDaily        GscPageDaily[]
  linksFrom       Link[]    @relation("LinksFrom")
  linksTo         Link[]    @relation("LinksTo")
  alerts          Alert[]
  seoEvents       SeoEvent[]
  backlinks       BacklinkSnapshot[]
  trackedKeywords TrackedKeyword[]
  
  @@unique([domainId, path])
  @@index([domainId, indexingVerdict])
  @@index([domainId, clicks(sort: Desc)])
  @@index([url])
}

model ManualCost {
  id          String       @id @default(cuid())
  
  category    CostCategory
  label       String       // np. "AWS EC2 eu-central-1", "ZUS marzec 2026"
  amount      Float        // kwota w PLN
  date        DateTime     @db.Date
  
  // Opcjonalne powiązanie z domeną
  domainId    String?
  domain      Domain?      @relation(fields: [domainId], references: [id])
  
  isRecurring Boolean      @default(false)  // czy powtarza się co miesiąc
  notes       String?
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  
  @@index([date])
  @@index([category])
  @@index([domainId])
}

enum CostCategory {
  GOOGLE_ADS
  INFRASTRUCTURE  // AWS, serwery, domeny, SSL
  TAXES           // podatek dochodowy, VAT
  ZUS             // składki ZUS
  TOOLS           // narzędzia: Moz, Stripe fees, inne SaaS
  MARKETING       // inne koszty marketingowe
  OTHER
}


model TrackedKeyword {
  id              String    @id @default(cuid())
  pageId          String
  page            Page      @relation(fields: [pageId], references: [id], onDelete: Cascade)
  
  keyword         String
  
  // Latest position
  position        Float?
  clicks          Int       @default(0)
  impressions     Int       @default(0)
  ctr             Float?
  
  // History
  positionHistory Json?     // [{date, position, clicks, impressions}]
  
  lastChecked     DateTime?
  createdAt       DateTime  @default(now())
  
  @@unique([pageId, keyword])
  @@index([pageId])
}

enum IndexingVerdict {
  PASS
  FAIL
  NEUTRAL
  UNKNOWN
  UNCHECKED
}

// ============================================
// GSC METRICS
// ============================================

// Domain-level daily aggregates
model GscDomainDaily {
  id              String    @id @default(cuid())
  domainId        String
  domain          Domain    @relation(fields: [domainId], references: [id], onDelete: Cascade)
  
  date            DateTime  @db.Date
  clicks          Int       @default(0)
  impressions     Int       @default(0)
  ctr             Float?
  position        Float?
  
  @@unique([domainId, date])
  @@index([domainId, date(sort: Desc)])
}

// Page-level daily metrics
model GscPageDaily {
  id              String    @id @default(cuid())
  pageId          String
  page            Page      @relation(fields: [pageId], references: [id], onDelete: Cascade)
  
  date            DateTime  @db.Date
  clicks          Int       @default(0)
  impressions     Int       @default(0)
  ctr             Float?
  position        Float?
  
  // Top queries for this page on this day
  topQueries      Json?     // [{query, clicks, impressions, position}]
  
  @@unique([pageId, date])
  @@index([pageId, date(sort: Desc)])
}

// ============================================
// LINKS
// ============================================

model Link {
  id              String    @id @default(cuid())
  
  fromPageId      String
  fromPage        Page      @relation("LinksFrom", fields: [fromPageId], references: [id], onDelete: Cascade)
  
  // For internal links
  toPageId        String?
  toPage          Page?     @relation("LinksTo", fields: [toPageId], references: [id], onDelete: SetNull)
  
  // For external links (toPageId is null)
  toUrl           String
  
  anchorText      String?
  isInternal      Boolean   @default(true)
  isBroken        Boolean   @default(false)
  statusCode      Int?
  
  // nofollow, ugc, sponsored
  relAttributes   String[]
  
  lastChecked     DateTime  @default(now())
  createdAt       DateTime  @default(now())
  
  @@unique([fromPageId, toUrl])
  @@index([fromPageId])
  @@index([toPageId])
  @@index([isBroken])
}

// ============================================
// ALERTS
// ============================================

model Alert {
  id              String    @id @default(cuid())
  domainId        String
  domain          Domain    @relation(fields: [domainId], references: [id], onDelete: Cascade)
  
  pageId          String?
  page            Page?     @relation(fields: [pageId], references: [id], onDelete: SetNull)
  
  type            AlertType
  severity        AlertSeverity @default(MEDIUM)
  title           String
  description     String?
  
  isResolved      Boolean   @default(false)
  resolvedAt      DateTime?
  
  createdAt       DateTime  @default(now())
  
  @@index([domainId, isResolved, createdAt(sort: Desc)])
  @@index([type])
}

enum AlertType {
  // Indexing
  PAGE_DEINDEXED       // PASS → FAIL/NEUTRAL
  PAGE_INDEXED         // UNCHECKED/NEUTRAL/FAIL → PASS (nowa!)
  NEW_PAGE_NOT_INDEXED // in sitemap >7 days, still not PASS

  // Traffic & Performance (GSC)
  TRAFFIC_DROP         // >30% click drop week-over-week
  POSITION_DROP        // avg position dropped >5 positions

  // Conversions & Revenue (GA4)
  CONVERSION_DROP      // >30% conversion drop week-over-week
  CONVERSION_SPIKE     // >50% conversion increase (positive alert)
  REVENUE_DROP         // >30% revenue drop week-over-week

  // Links
  BROKEN_LINK          // outbound 404
  BACKLINK_NEW         // new high-DA backlink discovered (Moz)
  BACKLINK_LOST        // existing backlink lost (Moz)

  // Moz / Authority
  DA_CHANGE            // Domain Authority changed by ≥2 points

  // Merchant Center
  MERCHANT_DISAPPROVED // product(s) got disapproved
  FEED_APPROVAL_DROP   // approval rate dropped >5%

  // Technical
  CRAWL_ERROR          // fetch error during link crawl
  SITEMAP_CHANGE       // pages added/removed from sitemap
}


enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ============================================
// JOBS LOG
// ============================================

model JobRun {
  id              String    @id @default(cuid())
  jobName         String    // "gsc_pull", "link_crawl", "sitemap_sync", "indexing_check"
  status          JobStatus @default(RUNNING)
  
  startedAt       DateTime  @default(now())
  finishedAt      DateTime?
  
  domainsProcessed Int      @default(0)
  pagesProcessed   Int      @default(0)
  errors           Int      @default(0)
  
  details         Json?     // per-domain results
  errorLog        String?   @db.Text
  
  @@index([jobName, startedAt(sort: Desc)])
}

// ============================================
// SEO TIMELINE — historia wydarzeń
// ============================================

model SeoEvent {
  id              String    @id @default(cuid())
  domainId        String
  domain          Domain    @relation(fields: [domainId], references: [id], onDelete: Cascade)
  
  pageId          String?
  page            Page?     @relation(fields: [pageId], references: [id], onDelete: SetNull)
  
  type            SeoEventType
  
  // Event data (flexible JSON)
  data            Json?
  
  // For quick filtering
  importance      Int       @default(1)  // 1=low, 2=medium, 3=high
  
  createdAt       DateTime  @default(now())
  
  @@index([domainId, createdAt(sort: Desc)])
  @@index([pageId, createdAt(sort: Desc)])
  @@index([type, createdAt(sort: Desc)])
}

enum SeoEventType {
  // Links
  BACKLINK_NEW           // new external link discovered
  BACKLINK_LOST          // external link disappeared
  INTERNAL_LINK_NEW      // new internal link
  INTERNAL_LINK_LOST     // internal link removed
  
  // Positions
  POSITION_IMPROVED      // position went up significantly
  POSITION_DROPPED       // position went down significantly
  ENTERED_TOP3           // entered top 3
  ENTERED_TOP10          // entered top 10
  LEFT_TOP10             // dropped out of top 10
  
  // Indexing
  PAGE_INDEXED           // UNCHECKED/NEUTRAL → PASS
  PAGE_DEINDEXED         // PASS → FAIL/NEUTRAL
  PAGE_FIRST_CRAWL       // Google crawled for first time
  
  // Content
  PAGE_ADDED_SITEMAP     // new page in sitemap
  PAGE_REMOVED_SITEMAP   // page removed from sitemap
  
  // Traffic
  TRAFFIC_SPIKE          // unusual traffic increase
  TRAFFIC_DROP           // unusual traffic decrease
}

model WatchedKeyword {
  id              String    @id @default(cuid())
  keyword         String    @unique
  
  // Latest aggregated data
  totalPages      Int       @default(0)
  bestPosition    Float?
  bestDomain      String?
  bestUrl         String?
  
  // Per-domain results (JSON array)
  // [{domainId, domain, url, path, position, clicks, impressions, ctr}]
  results         Json?
  
  // History
  // [{date, results: [{domain, url, position, clicks}]}]  
  positionHistory Json?
  
  lastChecked     DateTime?
  createdAt       DateTime  @default(now())
  
  @@index([keyword])
}

model DomainKeyword {
  id              String    @id @default(cuid())
  domainId        String
  domain          Domain    @relation(fields: [domainId], references: [id], onDelete: Cascade)
  
  keyword         String
  
  // Results: [{url, path, position, clicks, impressions, ctr}]
  results         Json?
  positionHistory Json?     // [{date, bestPosition, pages}]
  
  bestPosition    Float?
  totalClicks     Int       @default(0)
  totalPages      Int       @default(0)
  
  lastChecked     DateTime?
  createdAt       DateTime  @default(now())
  
  @@unique([domainId, keyword])
  @@index([domainId])
}


model LinkProposal {
  id            String    @id @default(cuid())
  domainId      String
  type          String    // CROSSLINK | INTERNAL
  
  sourceUrl     String
  sourcePath    String
  sourceDomain  String
  
  targetUrl     String
  targetPath    String
  targetDomain  String
  
  anchorText    String
  context       String?   @db.Text
  reason        String    @db.Text
  
  githubRepo    String
  filePath      String
  originalCode  String    @db.Text
  proposedCode  String    @db.Text
  
  status        String    @default("PENDING")
  
  approvedAt    DateTime?
  committedAt   DateTime?
  commitSha     String?
  
  createdAt     DateTime  @default(now())
  
  @@index([domainId, status])
  @@index([status, createdAt(sort: Desc)])
}

// Backlink snapshots — track external links pointing to our domains
model BacklinkSnapshot {
  id              String    @id @default(cuid())
  domainId        String
  domain          Domain    @relation(fields: [domainId], references: [id], onDelete: Cascade)
  
  // Target page on our domain
  pageId          String?
  page            Page?     @relation(fields: [pageId], references: [id], onDelete: SetNull)
  targetUrl       String
  
  // Source (external site)
  sourceUrl       String
  sourceDomain    String
  anchorText      String?
  
  // Status
  isLive          Boolean   @default(true)
  firstSeen       DateTime  @default(now())
  lastSeen        DateTime  @default(now())
  lastChecked     DateTime  @default(now())
  lostAt          DateTime?

  mozSourceDA     Float?
  mozSourcePA     Float?
  mozSourceSpam   Float?
  source          String    @default("CRAWL")
  
  // Metadata
  isDofollow      Boolean   @default(true)
  statusCode      Int?
  
  @@unique([domainId, sourceUrl, targetUrl])
  @@index([domainId, isLive])
  @@index([domainId, firstSeen(sort: Desc)])
  @@index([sourceDomain])
}

model ChatConversation {
  id        String    @id @default(cuid())
  title     String?   // auto-generated from first message
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  messages  ChatMessage[]
  
  @@index([updatedAt(sort: Desc)])
}

model ChatMessage {
  id             String    @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  role           String    // "user" | "assistant"
  content        String    @db.Text
  context       String?   @db.Text  // full system prompt + data sent to Claude
  
  // Metadata (assistant only)
  matchedDomain  String?
  inputTokens    Int?
  outputTokens   Int?
  durationMs     Int?
  
  createdAt      DateTime  @default(now())
  
  @@index([conversationId, createdAt])
}


model ApiLog {
  id            String    @id @default(cuid())
  provider      String    @default("anthropic")
  model         String
  endpoint      String
  
  inputTokens   Int       @default(0)
  outputTokens  Int       @default(0)
  totalTokens   Int       @default(0)
  
  costUsd       Float     @default(0)
  durationMs    Int       @default(0)
  
  feature       String?   // "crosslink_analysis", "internal_analysis", "code_generation"
  domainId      String?
  domainLabel   String?
  
  promptPreview String?   @db.Text
  responsePreview String? @db.Text
  
  status        String    @default("OK")
  error         String?
  
  metadata      Json?
  
  createdAt     DateTime  @default(now())
  
  @@index([createdAt(sort: Desc)])
  @@index([feature, createdAt(sort: Desc)])
  @@index([domainId])
}

model DomainIntegration {
  id          String    @id @default(cuid())
  domainId    String
  domain      Domain    @relation(fields: [domainId], references: [id], onDelete: Cascade)
  
  provider    IntegrationProvider
  
  // Provider-specific config
  propertyId  String?   // GA4: "properties/123456789"
  merchantId  String?   // Merchant Center: "123456"
  adsCustomerId String? // Google Ads: "123-456-7890"
  
  // OAuth (only for Google Ads — phase 2)
  oauthRefreshToken String?
  oauthExpiresAt    DateTime?
  
  // Status
  status      IntegrationStatus @default(PENDING)
  lastSync    DateTime?
  lastError   String?
  syncCount   Int       @default(0)
  
  // Cached summary — last snapshot of key metrics
  cachedData  Json?
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Daily snapshots
  dailyData   IntegrationDaily[]
  
  @@unique([domainId, provider])
  @@index([domainId])
  @@index([provider, status])
}

model IntegrationDaily {
  id              String    @id @default(cuid())
  integrationId   String
  integration     DomainIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  
  date            DateTime  @db.Date
  
  // ─── GA4 metrics ───
  sessions        Int?
  users           Int?
  newUsers        Int?
  pageviews       Int?
  avgSessionDuration Float?
  bounceRate      Float?
  conversions     Int?
  revenue         Float?
  
  // ─── Google Ads metrics ───
  adClicks        Int?
  adImpressions   Int?
  adCost          Float?
  adConversions   Int?
  adConversionValue Float?
  adCtr           Float?
  adCpc           Float?
  adRoas          Float?
  
  // ─── Merchant Center metrics ───
  productCount    Int?
  approvedProducts Int?
  disapprovedProducts Int?
  pendingProducts Int?
  
  // Flexible breakdowns (bySource, byCampaign, byProduct etc.)
  breakdown       Json?
  
  @@unique([integrationId, date])
  @@index([integrationId, date(sort: Desc)])
}


// ============================================
// GOOGLE ADS
// ============================================

model AdsCampaignDaily {
  id              String    @id @default(cuid())
  domainId        String
  
  campaignId      String
  campaignName    String
  campaignType    String    // PERFORMANCE_MAX, SHOPPING, SEARCH
  
  date            DateTime  @db.Date
  cost            Float     @default(0)     // in PLN
  clicks          Int       @default(0)
  impressions     Int       @default(0)
  conversions     Float     @default(0)
  conversionValue Float     @default(0)     // revenue in PLN
  ctr             Float?
  cpc             Float?                    // cost per click
  roas            Float?                    // return on ad spend
  
  createdAt       DateTime  @default(now())
  
  @@unique([campaignId, date])
  @@index([domainId, date(sort: Desc)])
  @@index([campaignId, date(sort: Desc)])
}

model AdsProductDaily {
  id              String    @id @default(cuid())
  domainId        String
  
  productId       String    // Merchant Center product ID
  productTitle    String
  productCategory String?
  
  date            DateTime  @db.Date
  cost            Float     @default(0)
  clicks          Int       @default(0)
  impressions     Int       @default(0)
  conversions     Float     @default(0)
  conversionValue Float     @default(0)
  ctr             Float?
  roas            Float?
  
  createdAt       DateTime  @default(now())
  
  @@unique([productId, date])
  @@index([domainId, date(sort: Desc)])
}

model AdsSearchTerm {
  id              String    @id @default(cuid())
  domainId        String
  
  searchTerm      String
  campaignId      String
  campaignName    String
  
  date            DateTime  @db.Date
  cost            Float     @default(0)
  clicks          Int       @default(0)
  impressions     Int       @default(0)
  conversions     Float     @default(0)
  conversionValue Float     @default(0)
  
  createdAt       DateTime  @default(now())
  
  @@unique([searchTerm, campaignId, date])
  @@index([domainId, date(sort: Desc)])
  @@index([searchTerm])
}

enum IntegrationProvider {
  GOOGLE_ANALYTICS
  GOOGLE_ADS
  GOOGLE_MERCHANT
}

enum IntegrationStatus {
  PENDING
  ACTIVE
  ERROR
  DISCONNECTED
}

enum JobStatus {
  RUNNING
  COMPLETED
  FAILED
}

